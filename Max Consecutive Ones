class Solution {
    public int findMaxConsecutiveOnes(int[] nums) {
        int count =0;
        for(int i=0;i<nums.length;i++)
        {
            int count1=0;
            for(int j=i;j<nums.length;j++){
                if(nums[j]==0)break;
                count1++;
            }count=Math.max(count,count1);
        }return count;
        
    }
}
